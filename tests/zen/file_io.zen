-- STRM-01: source() reads files line-by-line
-- Count lines from a plain text file
print(source("tests/zen/fixtures/sample.txt") |> count())

-- Collect lines from plain text file
print(source("tests/zen/fixtures/sample.txt") |> collect())

-- STRM-15: JSONL source with format dispatch
-- source with format: :jsonl parses each line as JSON wrapped in Result
let results = source("tests/zen/fixtures/sample.jsonl", :jsonl) |> collect()
print(len(results))

-- First record should be Ok with a map (unwrap Option from List.get)
let first = Option.unwrap_or(List.get(results, 0), nil)
print(Result.is_ok(first))

-- Third record (malformed JSON) should be Err
let third = Option.unwrap_or(List.get(results, 2), nil)
print(Result.is_err(third))

-- STRM-09: sink() writes stream to file (plain text)
range(1, 4) |> sink("/tmp/zen_e2e_sink_test.txt")
print(source("/tmp/zen_e2e_sink_test.txt") |> collect())

-- sink with JSONL format
range(1, 4) |> sink("/tmp/zen_e2e_sink_jsonl.jsonl", :jsonl)
print(source("/tmp/zen_e2e_sink_jsonl.jsonl") |> count())

-- SINK-CSV: sink with CSV format (records -> CSV with headers)
[{name: "alice", age: 30, city: "NYC"}, {name: "bob", age: 25, city: "LA"}]
  |> sink("/tmp/zen_e2e_csv.csv", :csv)
print(source("/tmp/zen_e2e_csv.csv") |> collect())

-- SINK-TSV: sink with TSV format
[{name: "alice", age: 30}, {name: "bob", age: 25}]
  |> sink("/tmp/zen_e2e_tsv.tsv", :tsv)
print(source("/tmp/zen_e2e_tsv.tsv") |> collect())

-- SINK-CSV-NOHDR: CSV without header row
[{x: 1, y: 2}, {x: 3, y: 4}]
  |> sink("/tmp/zen_e2e_csv_noh.csv", :csv, {header: false})
print(source("/tmp/zen_e2e_csv_noh.csv") |> collect())

-- SINK-APPEND: append mode
range(1, 3) |> sink("/tmp/zen_e2e_append.txt")
range(3, 5) |> sink("/tmp/zen_e2e_append.txt", :text, {append: true})
print(source("/tmp/zen_e2e_append.txt") |> count())

-- SINK-JSON-PRETTY: pretty-printed JSON
[{name: "alice"}, {name: "bob"}]
  |> sink("/tmp/zen_e2e_pretty.json", :json_pretty)
print(source("/tmp/zen_e2e_pretty.json") |> count())

-- SINK-TABLE: pretty table to file
[{name: "alice", age: 30}, {name: "bob", age: 25}]
  |> sink("/tmp/zen_e2e_table.txt", :table)
print(source("/tmp/zen_e2e_table.txt") |> count())

-- SINK-MARKDOWN: markdown table to file
[{name: "alice", age: 30}, {name: "bob", age: 25}]
  |> sink("/tmp/zen_e2e_md.txt", :markdown)
print(source("/tmp/zen_e2e_md.txt") |> count())
