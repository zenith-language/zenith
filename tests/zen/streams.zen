-- Comprehensive stream e2e tests covering Phase 5 requirement IDs
-- TYPE-08, STRM-02, STRM-03, STRM-04, STRM-05, STRM-06, STRM-07,
-- STRM-08, STRM-10, STRM-11, STRM-12

-- TYPE-08: Stream is a first-class type
print(type_of(repeat(1)))

-- STRM-02: Generators (range, repeat, iterate)
-- Note: tick() deferred to Phase 7 (requires fiber scheduler)
print(repeat(42) |> take(3) |> collect())
print(iterate(1, |x| x * 2) |> take(5) |> collect())
print(range(1, 6) |> collect())

-- STRM-03: Transforms (map, filter, flat_map, filter_map)
print(range(1, 6) |> map(|x| x * 10) |> collect())
print(range(1, 11) |> filter(|x| x > 7) |> collect())
print(range(1, 4) |> flat_map(|x| repeat(x) |> take(2)) |> collect())
print(range(1, 6) |> filter_map(|x| {
  if x > 3 { Option.Some(x * 10) } else { Option.None }
}) |> collect())

-- STRM-04: take/drop
print(range(1, 11) |> take(3) |> collect())
print(range(1, 11) |> drop(7) |> collect())

-- STRM-05: scan/distinct
print(range(1, 6) |> scan(0, |acc, x| acc + x) |> collect())
print(range(1, 4) |> flat_map(|x| repeat(x) |> take(2)) |> distinct() |> collect())

-- STRM-06: zip/flatten
print(range(1, 4) |> zip(range(10, 13)) |> collect())
print(range(1, 4) |> map(|x| [x, x * 10]) |> flatten() |> collect())

-- STRM-07: tap (side-effect without altering stream)
let tap_result = range(1, 4) |> tap(|x| x) |> collect()
print(tap_result)

-- STRM-08: batch
print(range(1, 8) |> batch(3) |> collect())

-- STRM-10: Terminals (sum, reduce, first, last, min, max, count)
print(range(1, 11) |> sum())
print(range(1, 6) |> reduce(0, |acc, x| acc + x))
print(range(1, 6) |> first())
print(range(1, 6) |> last())
print(range(1, 6) |> min())
print(range(1, 6) |> max())
print(range(1, 11) |> count())
