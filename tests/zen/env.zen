-- ENV-01: env() reads existing environment variable
-- HOME is always set on Unix systems
let home = env("HOME")
print(String.length(home) > 0)

-- ENV-02: env() with default for missing variable
let missing = env("ZENITH_NONEXISTENT_VAR_12345", "fallback")
print(missing)

-- ENV-03: env() without default returns Result.Err for missing variable
let err = env("ZENITH_NONEXISTENT_VAR_12345")
print(Result.is_err(err))

-- ENV-04: env() with default for existing variable returns the actual value (not default)
let path = env("PATH", "no-path")
print(String.length(path) > 0)
